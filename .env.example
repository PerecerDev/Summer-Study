# Database (Neon PostgreSQL — pooled connection string)
DATABASE_URL=postgresql://user:password@host/db?sslmode=require

# Groq LLM (free tier — https://console.groq.com/keys)
GROQ_API_KEY=
LLM_MODEL=llama-3.3-70b-versatile
LLM_BASE_URL=https://api.groq.com/openai/v1
# MOCK_LLM=true

# Session
SESSION_SECRET=change-me-to-a-long-random-string

# Vercel (production only — set in Vercel Dashboard)
# NODEJS_HELPERS=0

# App
NODE_ENV=development

# Seed (development only)
SEED_STUDENT_USERNAME=estudiante
SEED_STUDENT_PASSWORD=1234
SEED_STUDENT_DISPLAY_NAME=María
SEED_PARENT_PASSWORD=parent123

# API dev server port
API_PORT=3001
