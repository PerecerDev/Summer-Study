# Database (Neon PostgreSQL)
DATABASE_URL=postgresql://user:password@host/db?sslmode=require

# LLM (server-side only — never expose to client)
LLM_API_KEY=
LLM_MODEL=gpt-4o-mini
# MOCK_LLM=true

# Session
SESSION_SECRET=change-me-to-a-long-random-string

# Vercel (production only — set in Vercel Dashboard)
# NODEJS_HELPERS=0

# App
NODE_ENV=development

# Seed (development only)
SEED_STUDENT_USERNAME=estudiante
SEED_STUDENT_PASSWORD=1234
SEED_STUDENT_DISPLAY_NAME=María
SEED_PARENT_PASSWORD=parent123

# API dev server port
API_PORT=3001
